<%- include('partials/header') %>

<main>
    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="hero-bg-glow"></div>
        <div class="container hero-content">
            <h1 class="fade-in-up">Membangun Masa Depan Cerdas Bersama <span class="highlight-gold"><%= companyName %></span></h1>
            <p class="fade-in-up delay-1">Solusi Artificial Intelligence dan otomatisasi generasi berikutnya untuk mengakselerasi transformasi digital bisnis Anda tanpa batas.</p>
            <div class="hero-buttons fade-in-up delay-2">
                <a href="#services" class="btn-primary">Jelajahi Layanan</a>
                <a href="#contact" class="btn-secondary">Konsultasi Gratis</a>
            </div>
        </div>
    </section>

    <!-- Trusted By / Clients Section -->
    <section class="clients">
        <div class="container">
            <p class="clients-title text-center">Dipercaya oleh perusahaan-perusahaan inovatif dunia</p>
            <div class="clients-grid">
                <!-- Placeholder Logos using simple SVG or text for demo -->
                <div class="client-logo">
                    <span class="logo-placeholder">Acmecorp</span>
                </div>
                <div class="client-logo">
                    <span class="logo-placeholder">Globex</span>
                </div>
                <div class="client-logo">
                    <span class="logo-placeholder">Soylent</span>
                </div>
                <div class="client-logo">
                    <span class="logo-placeholder">Initech</span>
                </div>
                <div class="client-logo">
                    <span class="logo-placeholder">Umbrella</span>
                </div>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about">
        <div class="container">
            <div class="section-title">
                <h2>Tentang Kami</h2>
                <div class="underline"></div>
            </div>
            <div class="about-grid">
                <div class="about-text glass-card fade-in">
                    <h3>Visi & Teknologi Kami</h3>
                    <p>Di <%= companyName %>, kami memadukan kecerdasan buatan (AI) terdepan dengan arsitektur komputasi modern. Kami berdedikasi untuk menciptakan ekosistem bisnis otonom yang tidak hanya cerdas, namun juga adaptif terhadap masa depan.</p>
                    <ul class="feature-list">
                        <li>Integrasi Machine Learning</li>
                        <li>Analisis Data Prediktif</li>
                        <li>Infrastruktur Cloud-Native</li>
                    </ul>
                </div>
                <div class="about-stats">
                    <div class="stat-card glass-card">
                        <h4 class="stat-number">10+</h4>
                        <p>Tahun Pengalaman</p>
                    </div>
                    <div class="stat-card glass-card">
                        <h4 class="stat-number">500+</h4>
                        <p>Klien Global</p>
                    </div>
                    <div class="stat-card glass-card">
                        <h4 class="stat-number">99%</h4>
                        <p>Tingkat Kepuasan</p>
                    </div>
                    <div class="stat-card glass-card">
                        <h4 class="stat-number">24/7</h4>
                        <p>Dukungan Penuh</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="services">
        <div class="container">
            <div class="section-title text-center">
                <h2>Layanan Unggulan Kami</h2>
                <div class="underline mx-auto"></div>
                <p>Kami menawarkan spektrum solusi lengkap yang dirancang khusus untuk memenuhi kebutuhan unik perusahaan Anda.</p>
            </div>
            
            <div class="services-grid">
                <div class="service-card glass-card hover-lift">
                    <div class="service-icon">🧠</div>
                    <h3>AI & Machine Learning</h3>
                    <p>Membangun model kecerdasan buatan yang disesuaikan untuk mengotomatiskan keputusan kompleks dan memberdayakan data di perusahaan Anda.</p>
                </div>
                <div class="service-card glass-card hover-lift">
                    <div class="service-icon">⚡</div>
                    <h3>Otomatisasi Cerdas</h3>
                    <p>Mengurangi beban kerja repetitif dengan sistem otomasi pintar yang dapat belajar dan beradaptasi secara real-time dari pola bisnis Anda.</p>
                </div>
                <div class="service-card glass-card hover-lift">
                    <div class="service-icon">🛡️</div>
                    <h3>Cyber-AI Security</h3>
                    <p>Sistem deteksi ancaman otonom berbasis jaringan neural untuk memantau dan melindungi infrastruktur digital dari serangan siber zero-day.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Call to Action -->
    <section class="cta">
        <div class="container cta-container glass-card text-center">
            <h2>Siap Mendominasi Pasar?</h2>
            <p>Bergabunglah dengan ratusan perusahaan top lainnya yang telah mempercayakan kesuksesan mereka bersama <%= companyName %>.</p>
            <a href="#contact" class="btn-primary">Mulai Sekarang</a>
        </div>
    </section>
</main>

<%- include('partials/footer') %>
